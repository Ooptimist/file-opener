{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "FileOpener",
  "version": "0.1.0",
  "identifier": "com.autoopen.fileopener",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "文件批量打开工具",
        "width": 1600,
        "height": 1000,
        "minWidth": 1000,
        "minHeight": 700,
        "decorations": false,
        "shadow": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
